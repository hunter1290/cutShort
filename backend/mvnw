# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script, version 3.3.2
# ----------------------------------------------------------------------------

# If JAVA_HOME is set, use it; otherwise use java from PATH
if [ -n "$JAVA_HOME" ]; then
  JAVACMD="$JAVA_HOME/bin/java"
else
  JAVACMD="java"
fi

# Locate the script itself (handles symlinks)
PRG="$0"
while [ -h "$PRG" ]; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG="$(dirname "$PRG")/$link"
  fi
done
PRGDIR="$(cd "$(dirname "$PRG")" && pwd)"

# Maven Wrapper JAR and properties
MAVEN_WRAPPER_JAR="$PRGDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$PRGDIR/.mvn/wrapper/maven-wrapper.properties"

# Read distributionUrl from properties
DISTRIBUTION_URL=$(grep '^distributionUrl=' "$MAVEN_WRAPPER_PROPERTIES" | sed 's/distributionUrl=//')
WRAPPER_URL=$(grep '^wrapperUrl=' "$MAVEN_WRAPPER_PROPERTIES" | sed 's/wrapperUrl=//')

# Determine local Maven home from the distribution URL
MAVEN_FILENAME=$(basename "$DISTRIBUTION_URL")
MAVEN_HOME_DIR="${MAVEN_FILENAME%-bin.zip}"
MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2/wrapper/dists}"
MAVEN_HOME="$MAVEN_USER_HOME/$MAVEN_HOME_DIR/$MAVEN_HOME_DIR"

# Download and extract Maven if not already present
if [ ! -d "$MAVEN_HOME" ]; then
  echo "Downloading Maven $MAVEN_HOME_DIR ..."
  mkdir -p "$MAVEN_USER_HOME/$MAVEN_HOME_DIR"
  TMP_DOWNLOAD_DIR="$MAVEN_USER_HOME/$MAVEN_HOME_DIR/tmp"
  mkdir -p "$TMP_DOWNLOAD_DIR"
  ZIP_FILE="$TMP_DOWNLOAD_DIR/$(basename "$DISTRIBUTION_URL")"

  if command -v curl > /dev/null; then
    curl -fsSL -o "$ZIP_FILE" "$DISTRIBUTION_URL" || {
      echo "Error: Failed to download Maven from $DISTRIBUTION_URL"
      exit 1
    }
  elif command -v wget > /dev/null; then
    wget -q -O "$ZIP_FILE" "$DISTRIBUTION_URL" || {
      echo "Error: Failed to download Maven from $DISTRIBUTION_URL"
      exit 1
    }
  else
    echo "Error: curl or wget is required to download Maven"
    exit 1
  fi

  unzip -q "$ZIP_FILE" -d "$MAVEN_USER_HOME/$MAVEN_HOME_DIR"
  rm -rf "$TMP_DOWNLOAD_DIR"
  echo "Maven $MAVEN_HOME_DIR installed."
fi

MAVEN_CMD="$MAVEN_HOME/bin/mvn"

exec "$MAVEN_CMD" "$@"
